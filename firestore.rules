rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own document
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        // Guild members can read each other's data
        (resource.data.guildId != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.guildId == resource.data.guildId)
      );
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Any authenticated user can read guilds (needed for invite code lookup)
    // Only guild members can write to the guild
    match /guilds/{guildId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members ||
        request.auth.uid == resource.data.ownerId
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
    }
  }
}
